#!name=spotify歌词翻译
#!desc=spotify歌词翻译，百度翻译接口

[Script]
# 修改下方argument中的appid和securityKey,填入自己的appid和密钥
Spotify歌词翻译 = type=http-response, pattern=^https:\/\/spclient\.wg\.spotify\.com\/color-lyrics\/v2\/track\/, script-path=https://raw.githubusercontent.com/canff/loon/refs/heads/main/scripts/Spotify_lyric.js, requires-body=true, binary-body-mode=true, timeout=10

[MITM]
hostname = %APPEND% spclient.wg.spotify.com
